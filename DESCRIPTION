Package: treeSS
Type: Package
Title: Tree-Spatial Scan Statistic for Cluster Detection
Version: 0.1.18
Authors@R: c(
    person("Allan", "Quadros", email = "allanvcq@gmail.com",
           role = c("aut", "cre"),
